{
  "name": "nexus-7",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "description": "NEXUS-7 personalized life optimization system",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "db:check": "corepack pnpm --filter @nexus/memory db:check",
    "db:generate": "corepack pnpm --filter @nexus/memory db:generate",
    "dev:desktop": "corepack pnpm --filter @nexus/desktop dev",
    "dev:server": "corepack pnpm --filter @nexus/server dev",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "ai:probe": "tsx --env-file=.env scripts/probe-anthropic.ts",
    "ai:probe:any": "tsx --env-file=.env scripts/probe-ai.ts",
    "evals": "tsx scripts/run-evals.ts",
    "format": "biome format --write .",
    "utf8:guard": "tsx scripts/check-utf8.ts",
    "lint": "biome check .",
    "smoke": "tsx scripts/smoke-test.ts",
    "test": "corepack pnpm -r --if-present test",
    "typecheck": "corepack pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.18",
    "tsx": "^4.19.4",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@nestjs/core", "esbuild"]
  }
}
