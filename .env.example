NEXUS_PORT=3737
NEXUS_DB_PATH=./nexus-7.db
NEXUS_USER_ID=local-host
NEXUS_VAULT_PATH=./NEXUS-7

# AI Provider: auto | deterministic | anthropic | openai | gemini | deepseek | kimi
# auto = first provider with a key wins (priority: anthropic → openai → gemini → deepseek → kimi)
# deterministic = offline fixed replies, no API key needed
NEXUS_LLM_PROVIDER=auto

# Optional: override model names per tier (applies to whichever provider is active)
# NEXUS_LLM_MODEL_HAIKU=
# NEXUS_LLM_MODEL_SONNET=
# NEXUS_LLM_MODEL_OPUS=

# ── Anthropic (Claude) ──────────────────────────────────────────────────────
# Defaults: haiku=claude-haiku-4-5-20251001 / sonnet=claude-sonnet-4-6 / opus=claude-opus-4-8
ANTHROPIC_API_KEY=
# Proxy gateway alternative (mutually exclusive with API_KEY)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
# Legacy per-provider model overrides (NEXUS_LLM_MODEL_* takes precedence)
ANTHROPIC_MODEL_HAIKU=
ANTHROPIC_MODEL_SONNET=
ANTHROPIC_MODEL_OPUS=

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Defaults: haiku=gpt-4o-mini / sonnet=gpt-4o / opus=o1
OPENAI_API_KEY=

# ── Gemini (Google) ─────────────────────────────────────────────────────────
# Uses Google's OpenAI-compatible endpoint
# Defaults: haiku=gemini-2.0-flash / sonnet=gemini-2.0-flash / opus=gemini-2.5-pro
GEMINI_API_KEY=

# ── DeepSeek ────────────────────────────────────────────────────────────────
# Defaults: haiku=deepseek-chat / sonnet=deepseek-chat / opus=deepseek-reasoner
DEEPSEEK_API_KEY=

# ── Kimi (Moonshot AI) ──────────────────────────────────────────────────────
# Defaults: haiku=moonshot-v1-8k / sonnet=moonshot-v1-32k / opus=moonshot-v1-128k
KIMI_API_KEY=

# ActivityWatch local REST endpoint (default: http://localhost:5600)
NEXUS_AW_URL=http://localhost:5600
